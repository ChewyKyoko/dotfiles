#!/usr/bin/env bash
set -euo pipefail

WALLPAPER="${1:-}"

if [[ -z "$WALLPAPER" || ! -f "$WALLPAPER" ]]; then
    echo "Usage: $0 <wallpaper_path>" >&2
    exit 1
fi

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/quickshell"
mkdir -p "$CACHE_DIR"

# Persist the choice (plain text for autostart)
echo "$WALLPAPER" > "$CACHE_DIR/current-wallpaper"

# Persist as JSON for shell.qml's FileView watcher
cat > "$CACHE_DIR/wallpaper-state.json" <<EOF
{"wallpaper_path": "$WALLPAPER"}
EOF

# Quickshell renders the wallpaper via theme/Wallpaper.qml — no wbg needed
